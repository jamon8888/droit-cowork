{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Legal-FR document intake",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "filename": {
      "type": "string",
      "minLength": 1
    },
    "detected_type": {
      "type": "string",
      "enum": [
        "contract",
        "case_law",
        "email",
        "pleading",
        "lease",
        "employment",
        "financial",
        "unknown",
        "policy_or_contract",
        "supplier_agreement",
        "litigation_file",
        "court_decision",
        "employment_agreement",
        "lease_agreement",
        "amf_disclosure_file",
        "data_room_document"
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "fr",
        "en",
        "de",
        "other",
        "mixed"
      ]
    },
    "legal_domain": {
      "type": "string",
      "enum": [
        "contracts",
        "social",
        "baux",
        "contentieux",
        "capital_markets",
        "due_diligence",
        "unknown",
        "compliance",
        "contracts_supply",
        "litigation",
        "case_law",
        "employment",
        "real_estate"
      ]
    },
    "readability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "ocr_weak",
            "unreadable"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "status",
        "confidence"
      ]
    },
    "requires_human_triage": {
      "type": "boolean"
    }
  },
  "required": [
    "document_id",
    "filename",
    "detected_type",
    "language",
    "legal_domain",
    "readability",
    "requires_human_triage"
  ]
}
