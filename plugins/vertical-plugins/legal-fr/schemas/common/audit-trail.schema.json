{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Legal-FR audit trail",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "finding_id": {
      "type": "string"
    },
    "workflow": {
      "type": "string"
    },
    "document_id": {
      "type": "string"
    },
    "source_excerpt": {
      "type": "string"
    },
    "legal_source": {
      "$ref": "source-citation.schema.json"
    },
    "agent": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "human_validation": {
      "$ref": "human-validation.schema.json"
    }
  },
  "required": [
    "finding_id",
    "workflow",
    "document_id",
    "source_excerpt",
    "legal_source",
    "agent",
    "reviewer",
    "confidence",
    "human_validation"
  ]
}
